{
  "name": "gd-core-page-perf",
  "version": "0.0.1",
  "main": "index.js",
  "scripts": {
    "build": "rm -rf build/main.js && wp-scripts build",
    "lint:css": "wp-scripts lint-style 'src/**/*.scss'",
    "lint:js": "wp-scripts lint-js",
    "test:js": "wp-scripts test-unit-js --config ./tests/jest/jest.config.js",
    "test:js:coverage": "wp-scripts test-unit-js --config ./tests/jest/jest.config.js --coverage"
  },
  "dependencies": {
    "@wordpress/element": "~2.19.1",
    "@wordpress/icons": "~2.9.1",
    "@wordpress/primitives": "~1.11.1",
    "@wordpress/api-fetch": "~3.21.5",
    "classnames": "^2.2.6",
    "react": "^17.0.2",
    "react-circular-progressbar": "^2.0.4",
    "react-dom": "^17.0.2",
    "to-string-loader": "^1.1.6"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "7.10.4",
    "@babel/plugin-proposal-optional-chaining": "7.13.8",
    "@godaddy-wordpress/stylelint-config": "^0.2.0",
    "@testing-library/react-hooks": "^5.1.1",
    "@wordpress/components": "~12.0.8",
    "@wordpress/dependency-extraction-webpack-plugin": "3.1.0",
    "@wordpress/library-export-default-webpack-plugin": "^2.0.1",
    "@wordpress/scripts": "^13.0.3",
    "enzyme": "3.11.0",
    "eslint-plugin-chai-friendly": "^0.7.1"
  },
  "babel": {
    "presets": [
      "@wordpress/babel-preset-default"
    ],
    "plugins": [
      "@babel/plugin-proposal-class-properties",
      "@babel/plugin-proposal-optional-chaining"
    ]
  }
}
